# Django
DJANGO_SETTINGS_MODULE=core.settings
SECRET_KEY=django-insecure-key-here
DEBUG=False

ALLOWED_HOSTS=3.143.201.216,localhost,127.0.0.1,api.chefstarz.com
CORS_ALLOWED_ORIGINS=http://3.143.201.216,https://api.chefstarz.com
CSRF_TRUSTED_ORIGINS=http://3.143.201.216,https://api.chefstarz.com

# Database (RDS)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dbnamehere
DB_USER=dbuserhere
DB_PASSWORD=dbpasswordhere
DB_HOST=dbhosthere
DB_PORT=5432

# AWS S3
AWS_ACCESS_KEY_ID=accesskeyidhere
AWS_SECRET_ACCESS_KEY=someverysecretkeyhere
AWS_STORAGE_BUCKET_NAME=bucketnamehere
AWS_S3_REGION_NAME=us-east-2
AWS_S3_FILE_OVERWRITE=False
AWS_S3_VERIFY=True
AWS_DEFAULT_ACL=None

# Email (use Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=somehostuserhere@gmail.com
EMAIL_HOST_PASSWORD=somepasswordhere
DEFAULT_FROM_EMAIL=somefromemailhere

# Sentry (leave empty for now)
SENTRY_DSN=

# IMPORTANT: False until SSL cert is installed — True causes HTTP redirect loop
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Admin superuser
DJANGO_SUPERUSER_EMAIL=admin@chefstarz.com
DJANGO_SUPERUSER_PASSWORD=somepasshere
DJANGO_SUPERUSER_USERNAME=admin@chefstarz.com
